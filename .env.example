# ============================================
# Med Bio — Variáveis de Ambiente
# Copie para .env.local e preencha
# ============================================

# ---------------------------
# Supabase (substitui Firebase)
# Encontre em: supabase.com → seu projeto → Settings → API
# ---------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ---------------------------
# Gemini / Genkit
# Gere em: aistudio.google.com/apikey
# ---------------------------
GOOGLE_GENAI_API_KEY=sua_chave_gemini_aqui

# ---------------------------
# Segurança
# Gere com: openssl rand -hex 32
# ---------------------------
AUTOMATION_API_KEY=sua_chave_automacao_aqui
